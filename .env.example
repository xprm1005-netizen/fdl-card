# =====================================================
# FDL CARD — Environment Variables
# =====================================================
# Copy this file to .env.local for local development

# Supabase (클라이언트 - 퍼블릭)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Toss Payments (클라이언트 - 퍼블릭)
VITE_TOSS_CLIENT_KEY=test_ck_your-toss-client-key

# Admin email (클라이언트)
VITE_ADMIN_EMAIL=admin@fdlcard.com

# =====================================================
# Vercel 서버사이드 환경변수 (Vercel 대시보드에서 설정)
# =====================================================

# Supabase (서버 - Service Role Key, 절대 공개 금지)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# remove.bg API Key
REMOVEBG_API_KEY=your-removebg-api-key

# Toss Payments Secret Key (서버 - 절대 공개 금지)
TOSS_SECRET_KEY=test_sk_your-toss-secret-key

# Admin email (서버 - API 접근 제한)
ADMIN_EMAIL=admin@fdlcard.com
